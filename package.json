{
	"name": "obsidian-insert-path",
	"version": "0.1.2",
	"description": "Fuzzy-find any file or directory under a root and insert its path at the cursor.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit && node esbuild.config.mjs production",
		"dev:link": "node scripts/dev-link.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit -p tsconfig.test.json",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"fuzzy-finder",
		"fzf"
	],
	"author": "u-ways",
	"license": "MIT",
	"dependencies": {
		"fzf": "^0.5.2"
	},
	"devDependencies": {
		"@eslint/js": "^9",
		"@types/node": "^26",
		"@vitest/coverage-v8": "^4",
		"esbuild": "^0.28.1",
		"eslint": "^9",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^15",
		"obsidian": "latest",
		"prettier": "^3",
		"typescript": "^5",
		"typescript-eslint": "^8",
		"vitest": "^4"
	},
	"engines": {
		"node": ">=24"
	}
}
